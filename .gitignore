# macOS
.DS_Store

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.so
*.c

# Packaging
*.egg-info/
build/
dist/

# Jupyter
.ipynb_checkpoints/
# *.ipynb  # Notebooks are now tracked

# Cython build artifacts
.pyxbld/
*.c
*.html

# Large data files (>100MB)
tutorials/breast_cancer/data/*.parquet
tutorials/lung_cancer/data/*.parquet
**/data/*.parquet

# Zarr stores (large binary arrays)
**/*.zarr/
**/*.zarr/**

# Output files (optional - remove these lines if you want to commit outputs)
tutorials/*/output/*.parquet
output/*.parquet
tutorials/*/output/*.csv
output/*.csv
tutorials/*/output/*.h5ad
tutorials/*/output/*.json

# Plot images - exclude all PNG files EXCEPT those referenced in documentation
*.png
!assets/images/logo.png
!examples/output/10X.png
!examples/output/10X_transcripts.png
!examples/output/cell_124838_concave_refinement.png
!examples/output/v1_example.png
!tutorials/breast_cancer/plot/breast_cancer_mean_purity_conflict_transcript_scores.png
!tutorials/breast_cancer/plot/breast_cancer_umap_whole_cell_supervised_overlay.png
!tutorials/lung_cancer/plot/lung_cancer_mean_purity_conflict_transcript_scores.png
!tutorials/lung_cancer/plot/lung_cancer_umap_whole_cell.png
**/plot/*.png
**/plot/**/*.png

# Exclude melanoma tutorial folder entirely (large images and data)
# tutorials/melanoma/  # Re-enabled: melanoma notebooks are important

# Tutorial data files (optional)
tutorials/*/data/*.xlsx

# Logs and temporary files
*.log
/tmp/


# Ignore CSV and TSV files
*.csv.gz
*.tsv
tutorials/mouse_ileum/data/baysor_segmentation.csv
tutorials/lung_cancer/data/Baysor_segmentation.csv
