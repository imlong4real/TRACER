# macOS
.DS_Store

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.so
*.c

# Packaging
*.egg-info/
build/
dist/

# Jupyter
.ipynb_checkpoints/

# Ignore all Jupyter notebooks (avoid committing changes to notebooks)
*.ipynb

# Cython build artifacts
.pyxbld/
*.c
*.html

# Large data files (>100MB)
tutorials/breast_cancer/data/*.parquet
tutorials/lung_cancer/data/*.parquet
**/data/*.parquet

# Zarr stores (large binary arrays)
**/*.zarr/
**/*.zarr/**

# Output files (optional - remove these lines if you want to commit outputs)
tutorials/*/output/*.parquet
output/*.parquet
tutorials/*/output/*.h5ad
tutorials/*/output/*.json

# Ignore PNGs produced by plotting in any `plot/` folder
**/plot/*.png

# Tutorial data files (optional)
tutorials/*/data/*.xlsx

# Logs and temporary files
*.log
/tmp/

